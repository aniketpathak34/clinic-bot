DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True

# Groq (free: console.groq.com → API Keys)
GROQ_API_KEY=your-groq-api-key-here

# Meta WhatsApp Cloud API
# 1. Create a Meta Developer App → add WhatsApp product.
# 2. Add each clinic's phone number under the same WhatsApp Business Account.
# 3. Generate a permanent System User token with whatsapp_business_messaging +
#    whatsapp_business_management scopes. Use it here.
# Per-clinic phone_number_id / access_token are stored on the Clinic model.
META_ACCESS_TOKEN=your-permanent-system-user-token
META_DEFAULT_PHONE_NUMBER_ID=
META_GRAPH_API_VERSION=v21.0

# Webhook verify token — anything you choose; mirror it in Meta dashboard.
WHATSAPP_VERIFY_TOKEN=clinic-bot-verify

# WhatsApp service class
# Production:  apps.whatsapp.meta_service.MetaWhatsAppService
# Local dev:   apps.whatsapp.mock_service.MockWhatsAppService
WHATSAPP_SERVICE_CLASS=apps.whatsapp.mock_service.MockWhatsAppService

# Automated calls (mocked — no third-party service)
CALL_SERVICE_CLASS=apps.notifications.call_service.MockCallService

# Celery (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
