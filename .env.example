DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True

# Groq (free: console.groq.com → API Keys)
GROQ_API_KEY=your-groq-api-key-here

# MSG91 (WhatsApp + Voice + SMS — msg91.com)
MSG91_AUTH_KEY=your-msg91-authkey
MSG91_INTEGRATED_NUMBER=your-whatsapp-number-from-msg91
MSG91_IVR_FLOW_ID=your-ivr-flow-id

# WhatsApp Service (switch between mock and MSG91)
# Mock (dev): apps.whatsapp.mock_service.MockWhatsAppService
# MSG91 (prod): apps.whatsapp.msg91_service.MSG91WhatsAppService
WHATSAPP_SERVICE_CLASS=apps.whatsapp.mock_service.MockWhatsAppService
WHATSAPP_VERIFY_TOKEN=any-random-string-you-choose

# Automated Calls (switch between mock and MSG91)
# Mock (dev): apps.notifications.call_service.MockCallService
# MSG91 (prod): apps.notifications.call_service.MSG91CallService
CALL_SERVICE_CLASS=apps.notifications.call_service.MockCallService

# Celery (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
